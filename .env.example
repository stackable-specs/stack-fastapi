# Per docker-compose rule 12: every variable Compose interpolates is documented
# here. Copy to `.env` and fill in real values; `.env` itself is gitignored.

# Application
APP_ENVIRONMENT=local
APP_LOG_LEVEL=INFO
APP_DOCS_ENABLED=false

# Image tag selected at build / deploy time
IMAGE_TAG=dev

# Postgres credentials are injected via the `postgres_password` Compose secret
# (rule 13). Place the password in `secrets/postgres_password` (file is
# gitignored) and reference it by interpolation only when the API needs it in
# its DATABASE_URL string.
POSTGRES_PASSWORD=changeme

# OpenTelemetry (ADR-020). The SDK reads OTEL_* env vars directly
# (opentelemetry rule 2). For local dev these point at the OpenObserve
# container (ADR-021). In CI / production override OTEL_EXPORTER_OTLP_ENDPOINT
# and OTEL_EXPORTER_OTLP_HEADERS via the secret manager.
OTEL_EXPORTER_OTLP_ENDPOINT=http://openobserve:5080/api/default
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_SERVICE_NAME=python-uv-app
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# OpenObserve admin credentials (local dev only). Production uses an
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ... pair sourced from secrets.
ZO_ROOT_USER_EMAIL=root@example.com
ZO_ROOT_USER_PASSWORD=changeme

# Host port the OpenObserve UI is bound to. Default is shifted off 5080 so
# this stack does not collide with another local OTLP collector / OpenObserve
# instance. The api↔openobserve link uses the docker network (port 5080
# inside the container) and is unaffected by this value.
OPENOBSERVE_HOST_PORT=5180
