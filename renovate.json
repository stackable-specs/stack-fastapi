{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":dependencyDashboard"
  ],
  "timezone": "UTC",
  "schedule": ["after 8am and before 6pm every weekday"],
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2,
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate dependency dashboard",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"],
    "schedule": ["at any time"],
    "prCreation": "immediate",
    "automerge": false
  },
  "osvVulnerabilityAlerts": true,
  "configMigration": true,
  "packageRules": [
    {
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "python deps (non-major)",
      "schedule": ["after 8am and before 6pm on monday"]
    },
    {
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major"],
      "schedule": ["after 8am and before 6pm on monday"]
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "pinDigests": true,
      "groupName": "container base images"
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "groupName": "github actions"
    },
    {
      "matchPackageNames": [
        "fastapi",
        "pydantic",
        "pydantic-settings",
        "uvicorn"
      ],
      "groupName": "fastapi runtime"
    },
    {
      "matchPackageNames": ["/^opentelemetry-/"],
      "groupName": "opentelemetry"
    },
    {
      "description": "Auto-merge dev-only patch updates and lockfile maintenance only.",
      "matchUpdateTypes": ["patch", "pin", "digest", "lockFileMaintenance"],
      "matchDepTypes": ["devDependencies"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeStrategy": "squash"
    }
  ]
}
